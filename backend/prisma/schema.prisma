generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "linux-musl"]
  engineType    = "binary"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Planes {
  id_plan                 Int                  @id(map: "PK_Planes") @default(autoincrement())
  expediente              String?              @db.NVarChar(100)
  estado                  String               @db.NVarChar(50)
  nombre                  String               @db.NVarChar(255)
  solicitante             String?              @db.NVarChar(255)
  fecha_convocatoria_plan Int?
  responsable             String?              @db.NVarChar(255)
  fecha_inicio            DateTime?            @db.Date
  fecha_fin               DateTime?            @db.Date
  tipo_bonificacion       String?              @db.NVarChar(50)
  accionesFormativas      AccionesFormativas[]

  @@map("Planes")
}

model AreaProfesional {
  id_area                    Int                          @id(map: "PK_AreaProfesional") @default(autoincrement())
  abreviatura                String                       @db.NVarChar(20)
  nombre                     String                       @db.NVarChar(255)
  accionesFormativas         AccionesFormativas[]
  desgloseAreasProfesionales DesgloseAreasProfesionales[]

  @@map("AreaProfesional")
}

model DesgloseAreasProfesionales {
  id_desglose        Int                  @id(map: "PK_DesgloseAreasProfesionales") @default(autoincrement())
  id_area            Int
  codigo_grupo       String               @db.NVarChar(50)
  desglose           String               @db.NVarChar(255)
  accionesFormativas AccionesFormativas[]
  areaProfesional    AreaProfesional      @relation(fields: [id_area], references: [id_area], onUpdate: NoAction, map: "FK_DesgloseAreasProfesionales_id_area")

  @@index([id_area], map: "IX_DesgloseAreasProfesionales_id_area")
  @@map("DesgloseAreasProfesionales")
}

model AccionesFormativas {
  id_accion                     Int                         @id(map: "PK_AccionesFormativas") @default(autoincrement())
  denominacion                  String                      @db.NVarChar(255)
  numero_accion                 String?                     @db.NVarChar(50)
  modalidad                     String                      @db.NVarChar(50)
  id_area                       Int?
  id_desglose                   Int?
  codigo_grupo_accion           String?
  horas_modalidad_presencial    Int?
  horas_modalidad_teleformacion Int?
  cif_plataforma                String?                     @db.NVarChar(50)
  razon_social_plataforma       String?                     @db.NVarChar(255)
  uri                           String?                     @db.NVarChar(500)
  usuario                       String?                     @db.NVarChar(100)
  password                      String?                     @db.NVarChar(100)
  observaciones                 String?                     @db.NVarChar(Max)
  nivel_formacion               String?                     @db.NVarChar(50)
  objetivos                     String?                     @db.NVarChar(Max)
  contenido                     String?                     @db.NVarChar(Max)
  participantes                 Int?
  id_plan                       Int?
  es_seguridad_privada          Boolean                     @default(false, map: "DF_AccionesFormativas_es_seguridad_privada")
  horas_totales_diploma         Int?
  desglose_horas_diploma        String?                     @db.NVarChar(255)
  modalidad_diploma             String?                     @db.NVarChar(100)
  areaProfesional               AreaProfesional?            @relation(fields: [id_area], references: [id_area], onDelete: NoAction, onUpdate: NoAction, map: "FK_AccionesFormativas_id_area")
  desgloseAreasProfesionales    DesgloseAreasProfesionales? @relation(fields: [id_desglose], references: [id_desglose], onDelete: NoAction, onUpdate: NoAction, map: "FK_AccionesFormativas_id_desglose")
  plan                          Planes?                     @relation(fields: [id_plan], references: [id_plan], onDelete: NoAction, onUpdate: NoAction, map: "FK_AccionesFormativas_id_plan")
  grupos                        Grupos[]

  @@index([id_area], map: "IX_AccionesFormativas_id_area")
  @@index([id_desglose], map: "IX_AccionesFormativas_id_desglose")
  @@index([id_plan], map: "IX_AccionesFormativas_id_plan")
  @@map("AccionesFormativas")
}
// Añadimos los campos tipo_bonificacion y max_alumnos
model Grupos {
  id_grupo                                 Int                                 @id(map: "PK_Grupos") @default(autoincrement())
  estado                                   String?                             @db.NVarChar(50)
  codigo                                   String?                             @db.NVarChar(50)
  fecha_inicio                             DateTime?                           @db.Date
  fecha_fin                                DateTime?                           @db.Date
  denominacion                             String?                             @db.NVarChar(255)
  responsable                              String?                             @db.NVarChar(255)
  telefono_responsable                     String?                             @db.NVarChar(20)
  observaciones                            String?                             @db.NVarChar(Max)
  centro_cif                               String?                             @db.NVarChar(50)
  centro_nombre                            String?                             @db.NVarChar(255)
  centro_direccion                         String?                             @db.NVarChar(255)
  centro_codPostal                         String?                             @db.NVarChar(20)
  centro_localidad                         String?                             @db.NVarChar(100)
  lugar_imparticion_nombre                 String?                             @db.NVarChar(255)
  lugar_imparticion_direccion              String?                             @db.NVarChar(255)
  lugar_imparticion_codPostal              String?                             @db.NVarChar(20)
  lugar_imparticion_localidad              String?                             @db.NVarChar(100)
  horas_totales_presencial_horario         Int?
  hora_inicio_tramo1_presencial_horario    DateTime?                           @db.Time
  hora_fin_tramo1_presencial_horario       DateTime?                           @db.Time
  hora_inicio_tramo2_presencial_horario    DateTime?                           @db.Time
  hora_fin_tramo2_presencial_horario       DateTime?                           @db.Time
  dias_presencial_horario                  String?                             @db.NVarChar(50)
  aula_virtual                             Boolean                             @default(false, map: "DF__Grupos__aula_vir__0D7A0286")
  medio_aula_virtual                       String?                             @db.NVarChar(100)
  conexion_aula_virtual                    String?                             @db.NVarChar(100)
  contacto_aula_virtual                    String?                             @db.NVarChar(255)
  telefono_aula_virtual                    String?                             @db.NVarChar(20)
  bimodal_aula_virtual                     Boolean                             @default(false, map: "DF__Grupos__bimodal___0E6E26BF")
  sin_participantes_en_centro_aula_virtual Boolean                             @default(false, map: "DF__Grupos__sin_part__0F624AF8")
  sin_docentes_en_centro_aula_virtual      Boolean                             @default(false, map: "DF__Grupos__sin_doce__10566F31")
  tele_centro_cif                          String?                             @db.NVarChar(50)
  tele_centro_nombre                       String?                             @db.NVarChar(255)
  tele_centro_direccion                    String?                             @db.NVarChar(255)
  tele_centro_codPostal                    String?                             @db.NVarChar(20)
  tele_centro_localidad                    String?                             @db.NVarChar(100)
  tele_telefono                            String?                             @db.NVarChar(20)
  horas_totales_teleformacion              Int?
  hora_inicio_tramo1_tele                  DateTime?                           @db.Time
  hora_fin_tramo1_tele                     DateTime?                           @db.Time
  hora_inicio_tramo2_tele                  DateTime?                           @db.Time
  hora_fin_tramo2_tele                     DateTime?                           @db.Time
  dias_tele                                String?                             @db.NVarChar(50)
  id_accion                                Int?
  moodle_grupo_id                          String?                             @db.NVarChar(50)
  lugar_imparticion_cif                    String?                             @db.NVarChar(100)
  num_homologacion_seguridad               String?                             @db.NVarChar(100)
  lugar_fecha_diploma                      String?                             @db.NVarChar(255)
  tipo_bonificacion                        String?                             @db.NVarChar(50)
  max_alumnos                              Int?
  alumnosPersonaGrupo                      AlumnosPersonaGrupo[]
  costesGrupo                              CostesGrupo[]
  diasImparticionPresencial                DiasImparticionGrupoPresencial[]
  diasImparticionTeleformacion             DiasImparticionGrupoTeleformacion[]
  docentesPersonaGrupo                     DocentesPersonaGrupo[]
  documentacionAdjGrupo                    DocumentacionAdjGrupo[]
  emailLogs                                EmailLogs[]
  accionFormativa                          AccionesFormativas?                 @relation(fields: [id_accion], references: [id_accion], onDelete: NoAction, onUpdate: NoAction, map: "FK_Grupos_id_accion")
  tareas                                   Tareas[]

  @@index([id_accion], map: "IX_Grupos_id_accion")
  @@map("Grupos")
}

model CostesGrupo {
  id_coste            Int      @id(map: "PK_CostesGrupo") @default(autoincrement())
  id_grupo            Int
  cif                 String?  @db.NVarChar(50)
  directos            Decimal? @db.Decimal(10, 2)
  indirectos          Decimal? @db.Decimal(10, 2)
  organizacion        Decimal? @db.Decimal(10, 2)
  salariales          Decimal? @db.Decimal(10, 2)
  periodos_enero      Decimal? @db.Decimal(10, 2)
  periodos_febrero    Decimal? @db.Decimal(10, 2)
  periodos_marzo      Decimal? @db.Decimal(10, 2)
  periodos_abril      Decimal? @db.Decimal(10, 2)
  periodos_mayo       Decimal? @db.Decimal(10, 2)
  periodos_junio      Decimal? @db.Decimal(10, 2)
  periodos_julio      Decimal? @db.Decimal(10, 2)
  periodos_agosto     Decimal? @db.Decimal(10, 2)
  periodos_septiembre Decimal? @db.Decimal(10, 2)
  periodos_octubre    Decimal? @db.Decimal(10, 2)
  periodos_noviembre  Decimal? @db.Decimal(10, 2)
  periodos_diciembre  Decimal? @db.Decimal(10, 2)
  grupo               Grupos   @relation(fields: [id_grupo], references: [id_grupo], onUpdate: NoAction, map: "FK_CostesGrupo_id_grupo")

  @@index([id_grupo], map: "IX_CostesGrupo_id_grupo")
  @@map("CostesGrupo")
}

model Empresas {
  id_empresa              Int                       @id(map: "PK_Empresas") @default(autoincrement())
  razon_social            String                    @db.NVarChar(255)
  CIF                     String?                   @db.NVarChar(50)
  NSS                     String?                   @db.NVarChar(50)
  direccion               String?                   @db.NVarChar(255)
  persona_contacto        String?                   @db.NVarChar(255)
  telefono1               String?                   @db.NVarChar(20)
  telefono2               String?                   @db.NVarChar(20)
  fax                     String?                   @db.NVarChar(20)
  sector_actividad        String?                   @db.NVarChar(255)
  CNAE                    String?                   @db.NVarChar(50)
  CNAE2009                String?                   @db.NVarChar(50)
  correo_electronico      String?                   @db.NVarChar(100)
  pagina_web              String?                   @db.NVarChar(255)
  nombre_representante    String?                   @db.NVarChar(255)
  NIF_representante       String?                   @db.NVarChar(50)
  informa_RLT             String?                   @db.NVarChar(255)
  valor_informe           String?                   @db.NVarChar(10)
  fecha_discrepancia      DateTime?                 @db.Date
  resuelto                Boolean                   @default(false, map: "DF__Empresas__resuel__0C85DE4D")
  comentarios             String?                   @db.NVarChar(Max)
  centrosTrabajo          CentrosTrabajo[]
  documentacionAdjEmpresa DocumentacionAdjEmpresa[]

  @@map("Empresas")
}

model CentrosTrabajo {
  id_centro           Int                   @id(map: "PK_CentrosTrabajo") @default(autoincrement())
  nombre              String                @db.NVarChar(255)
  NSS                 String?               @db.NVarChar(50)
  direccion           String?               @db.NVarChar(255)
  persona_contacto    String?               @db.NVarChar(255)
  telefono1           String?               @db.NVarChar(20)
  telefono2           String?               @db.NVarChar(20)
  fax                 String?               @db.NVarChar(20)
  correo_electronico  String?               @db.NVarChar(100)
  cuenta_bancaria     String?               @db.NVarChar(50)
  IBAN                String?               @db.NVarChar(34)
  BIC                 String?               @db.NVarChar(11)
  id_empresa          Int?
  alumnosPersonaGrupo AlumnosPersonaGrupo[]
  empresa             Empresas?             @relation(fields: [id_empresa], references: [id_empresa], onDelete: NoAction, onUpdate: NoAction, map: "FK_CentrosTrabajo_id_empresa")

  @@index([id_empresa], map: "IX_CentrosTrabajo_id_empresa")
  @@map("CentrosTrabajo")
}

model Personas {
  id_persona                     Int                              @id(map: "PK_Personas") @default(autoincrement())
  tipoDocumento                  String                           @db.NVarChar(50)
  documento                      String                           @unique(map: "UQ_Personas_documento") @db.NVarChar(50)
  nombre                         String                           @db.NVarChar(100)
  apellido1                      String                           @db.NVarChar(100)
  apellido2                      String?                          @db.NVarChar(100)
  telefono                       String?                          @db.NVarChar(20)
  correoElectronico              String?                          @db.NVarChar(100)
  NSS                            String?                          @db.NVarChar(20)
  es_docente                     Boolean                          @default(false, map: "DF__Personas__es_doc__114A936A")
  es_alumno                      Boolean                          @default(false, map: "DF__Personas__es_alu__123EB7A3")
  fecha_nacimiento               DateTime?                        @db.Date
  sexo                           String?                          @db.NVarChar(20)
  domicilio                      String?                          @db.NVarChar(255)
  discapacidad                   Boolean                          @default(false, map: "DF__Personas__discap__1332DBDC")
  afectadosTerrorismo            Boolean                          @default(false, map: "DF__Personas__afecta__14270015")
  afectadosViolenciaGenero       Boolean                          @default(false, map: "DF__Personas__afecta__151B244E")
  nivel_estudios                 Int?
  comentarios                    String?                          @db.NVarChar(Max)
  alumnosPersonaGrupo            AlumnosPersonaGrupo[]
  docentesPersonaGrupo           DocentesPersonaGrupo[]
  documentacionAdjAlumnoPersona  DocumentacionAdjAlumnoPersona[]
  documentacionAdjDocentePersona DocumentacionAdjDocentePersona[]
  emailLogs                      EmailLogs[]

  @@map("Personas")
}

model AlumnosPersonaGrupo {
  id_alumno_grupo       Int            @id(map: "PK_AlumnosPersonaGrupo") @default(autoincrement())
  id_persona            Int
  id_grupo              Int
  id_centro             Int
  fecha_inscripcion     DateTime?      @db.Date
  estado_curso          String?        @db.NVarChar(50)
  progreso_curso        String?        @db.NVarChar(100)
  diploma               String?        @db.NVarChar(50)
  jornada_laboral       Boolean        @default(false, map: "DF__AlumnosPe__jorna__02FC7413")
  fijo_discontinuo      Boolean        @default(false, map: "DF__AlumnosPe__fijo___03F0984C")
  categoria_profesional String?        @db.NVarChar(100)
  ERTE                  Boolean        @default(false, map: "DF__AlumnosPer__ERTE__04E4BC85")
  centro                CentrosTrabajo @relation(fields: [id_centro], references: [id_centro], onUpdate: NoAction, map: "FK_AlumnosPersonaGrupo_id_centro")
  grupo                 Grupos         @relation(fields: [id_grupo], references: [id_grupo], onUpdate: NoAction, map: "FK_AlumnosPersonaGrupo_id_grupo")
  persona               Personas       @relation(fields: [id_persona], references: [id_persona], onUpdate: NoAction, map: "FK_AlumnosPersonaGrupo_id_persona")

  @@index([id_centro], map: "IX_AlumnosPersonaGrupo_id_centro")
  @@index([id_grupo], map: "IX_AlumnosPersonaGrupo_id_grupo")
  @@index([id_persona], map: "IX_AlumnosPersonaGrupo_id_persona")
  @@map("AlumnosPersonaGrupo")
}

model DocentesPersonaGrupo {
  id_docente_grupo             Int                                 @id(map: "PK_DocentesPersonaGrupo") @default(autoincrement())
  id_persona                   Int
  id_grupo                     Int
  fecha_asignacion             DateTime?                           @db.Date
  tutoria                      Boolean                             @default(false, map: "DF__DocentesP__tutor__05D8E0BE")
  tipotutoria                  String?                             @db.NVarChar(50)
  descripcion                  String?                             @db.NVarChar(Max)
  modalidad                    String?                             @db.NVarChar(50)
  diasImparticionPresencial    DiasImparticionGrupoPresencial[]
  diasImparticionTeleformacion DiasImparticionGrupoTeleformacion[]
  grupo                        Grupos                              @relation(fields: [id_grupo], references: [id_grupo], onUpdate: NoAction, map: "FK_DocentesPersonaGrupo_id_grupo")
  persona                      Personas                            @relation(fields: [id_persona], references: [id_persona], onUpdate: NoAction, map: "FK_DocentesPersonaGrupo_id_persona")
  sesiones                     Sesiones[]

  @@index([id_grupo], map: "IX_DocentesPersonaGrupo_id_grupo")
  @@index([id_persona], map: "IX_DocentesPersonaGrupo_id_persona")
  @@map("DocentesPersonaGrupo")
}

model DocumentacionAdjAlumnoPersona {
  id_documento        Int      @id(map: "PK_DocumentacionAdjAlumnoPersona") @default(autoincrement())
  id_persona          Int
  tipo_documento      String
  nombre_archivo      String   @db.NVarChar(255)
  nombre_archivo_blob String?  @db.NVarChar(255)
  url_blob            String   @db.NVarChar(500)
  fecha_subida        DateTime @default(now(), map: "DF__Documenta__fecha__06CD04F7") @db.Date
  observaciones       String?  @db.NVarChar(Max)
  persona             Personas @relation(fields: [id_persona], references: [id_persona], onUpdate: NoAction, map: "FK_DocumentacionAdjAlumnoPersona_id_persona")

  @@index([id_persona], map: "IX_DocumentacionAdjAlumnoPersona_id_persona")
  @@map("DocumentacionAdjAlumnoPersona")
}

model DocumentacionAdjDocentePersona {
  id_documento        Int      @id(map: "PK_DocumentacionAdjDocentePersona") @default(autoincrement())
  id_persona          Int
  tipo_documento      String
  nombre_archivo      String   @db.NVarChar(255)
  nombre_archivo_blob String?  @db.NVarChar(255)
  url_blob            String   @db.NVarChar(500)
  fecha_subida        DateTime @default(now(), map: "DF__Documenta__fecha__07C12930") @db.Date
  observaciones       String?  @db.NVarChar(Max)
  persona             Personas @relation(fields: [id_persona], references: [id_persona], onUpdate: NoAction, map: "FK_DocumentacionAdjDocentePersona_id_persona")

  @@index([id_persona], map: "IX_DocumentacionAdjDocentePersona_id_persona")
  @@map("DocumentacionAdjDocentePersona")
}

model DocumentacionAdjEmpresa {
  id_documento        Int      @id(map: "PK_DocumentacionAdjEmpresa") @default(autoincrement())
  id_empresa          Int
  tipo_documento      String   @db.NVarChar(100)
  nombre_archivo      String   @db.NVarChar(255)
  nombre_archivo_blob String?  @db.NVarChar(255)
  url_blob            String   @db.NVarChar(500)
  fecha_subida        DateTime @default(now(), map: "DF__Documenta__fecha__08B54D69") @db.Date
  observaciones       String?  @db.NVarChar(Max)
  empresa             Empresas @relation(fields: [id_empresa], references: [id_empresa], onUpdate: NoAction, map: "FK_DocumentacionAdjEmpresa_id_empresa")

  @@index([id_empresa], map: "IX_DocumentacionAdjEmpresa_id_empresa")
  @@map("DocumentacionAdjEmpresa")
}

model DocumentacionAdjGrupo {
  id_documento        Int      @id(map: "PK_DocumentacionAdjGrupo") @default(autoincrement())
  id_grupo            Int
  tipo_documento      String   @db.NVarChar(100)
  nombre_archivo      String   @db.NVarChar(255)
  nombre_archivo_blob String?  @db.NVarChar(255)
  url_blob            String   @db.NVarChar(500)
  fecha_subida        DateTime @default(now(), map: "DF__Documenta__fecha__09A971A2") @db.Date
  observaciones       String?  @db.NVarChar(Max)
  grupo               Grupos   @relation(fields: [id_grupo], references: [id_grupo], onUpdate: NoAction, map: "FK_DocumentacionAdjGrupo_id_grupo")

  @@index([id_grupo], map: "IX_DocumentacionAdjGrupo_id_grupo")
  @@map("DocumentacionAdjGrupo")
}
// Añado los campos fecha_vencimiento y color 
model Tareas {
  id_tarea             Int     @id(map: "PK_Tareas") @default(autoincrement())
  id_grupo             Int?
  nombre_tarea         String  @db.NVarChar(255)
  estado               String  @default("Pendiente", map: "DF__Tareas__estado__17036CC0") @db.NVarChar(50)
  observaciones        String? @db.NVarChar(Max)
  autor_azure_id       String? @db.NVarChar(255)
  responsable_azure_id String? @db.NVarChar(255)
  fecha_vencimiento    DateTime? @db.Date
  color                String? @db.NVarChar(30)
  grupo                Grupos? @relation(fields: [id_grupo], references: [id_grupo], onUpdate: NoAction, map: "FK_Tareas_id_grupo")
  @@index([id_grupo], map: "IX_Tareas_id_grupo")
  @@map("Tareas")
}

model DiasImparticionGrupoTeleformacion {
  id_dia_tele           Int                   @id(map: "PK_DiasImparticionGrupoTeleformacion") @default(autoincrement())
  id_grupo              Int
  id_docente            Int?
  fecha_imparticion     DateTime              @db.Date
  horario_inicio_tramo1 DateTime?             @db.Time
  horario_fin_tramo1    DateTime?             @db.Time
  horario_inicio_tramo2 DateTime?             @db.Time
  horario_fin_tramo2    DateTime?             @db.Time
  docente               DocentesPersonaGrupo? @relation(fields: [id_docente], references: [id_docente_grupo], onDelete: NoAction, onUpdate: NoAction, map: "FK_DiasImparticionGrupoTeleformacion_id_docente")
  grupo                 Grupos                @relation(fields: [id_grupo], references: [id_grupo], onUpdate: NoAction, map: "FK_DiasImparticionGrupoTeleformacion_id_grupo")
  sesiones              Sesiones[]

  @@index([id_docente], map: "IX_DiasImparticionGrupoTeleformacion_id_docente")
  @@index([id_grupo], map: "IX_DiasImparticionGrupoTeleformacion_id_grupo")
  @@map("DiasImparticionGrupoTeleformacion")
}

model DiasImparticionGrupoPresencial {
  id_dia_pres           Int                   @id(map: "PK_DiasImparticionGrupoPresencial") @default(autoincrement())
  id_grupo              Int
  id_docente            Int?
  fecha_imparticion     DateTime              @db.Date
  horario_inicio_tramo1 DateTime?             @db.Time
  horario_fin_tramo1    DateTime?             @db.Time
  horario_inicio_tramo2 DateTime?             @db.Time
  horario_fin_tramo2    DateTime?             @db.Time
  docente               DocentesPersonaGrupo? @relation(fields: [id_docente], references: [id_docente_grupo], onDelete: NoAction, onUpdate: NoAction, map: "FK_DiasImparticionGrupoPresencial_id_docente")
  grupo                 Grupos                @relation(fields: [id_grupo], references: [id_grupo], onUpdate: NoAction, map: "FK_DiasImparticionGrupoPresencial_id_grupo")
  sesiones              Sesiones[]

  @@index([id_docente], map: "IX_DiasImparticionGrupoPresencial_id_docente")
  @@index([id_grupo], map: "IX_DiasImparticionGrupoPresencial_id_grupo")
  @@map("DiasImparticionGrupoPresencial")
}

model Sesiones {
  id_sesion        Int                                @id(map: "PK_Sesiones") @default(autoincrement())
  id_dia_tele      Int?
  id_dia_pres      Int?
  id_docente       Int?
  es_manana        Boolean                            @default(true, map: "DF__Sesiones__es_man__160F4887")
  horario_inicio   DateTime                           @db.Time
  horario_fin      DateTime                           @db.Time
  diaPresencial    DiasImparticionGrupoPresencial?    @relation(fields: [id_dia_pres], references: [id_dia_pres], onDelete: NoAction, onUpdate: NoAction, map: "FK_Sesiones_id_dia_pres")
  diaTeleformacion DiasImparticionGrupoTeleformacion? @relation(fields: [id_dia_tele], references: [id_dia_tele], onDelete: NoAction, onUpdate: NoAction, map: "FK_Sesiones_id_dia_tele")
  docente          DocentesPersonaGrupo?              @relation(fields: [id_docente], references: [id_docente_grupo], onDelete: NoAction, onUpdate: NoAction, map: "FK_Sesiones_id_docente")

  @@index([id_dia_pres], map: "IX_Sesiones_id_dia_pres")
  @@index([id_dia_tele], map: "IX_Sesiones_id_dia_tele")
  @@index([id_docente], map: "IX_Sesiones_id_docente")
  @@map("Sesiones")
}

model EmailLogs {
  id_email_log Int       @id(map: "PK_EmailLogs") @default(autoincrement())
  id_grupo     Int?
  id_persona   Int?
  tipo_envio   String    @db.NVarChar(50)
  fecha_envio  DateTime  @default(now(), map: "DF__EmailLogs__fecha__0A9D95DB")
  enviado      Boolean   @default(true, map: "DF__EmailLogs__envia__0B91BA14")
  grupo        Grupos?   @relation(fields: [id_grupo], references: [id_grupo], onDelete: NoAction, onUpdate: NoAction, map: "FK_EmailLogs_id_grupo")
  persona      Personas? @relation(fields: [id_persona], references: [id_persona], onDelete: NoAction, onUpdate: NoAction, map: "FK_EmailLogs_id_persona")

  @@index([id_grupo], map: "IX_EmailLogs_id_grupo")
  @@index([id_persona], map: "IX_EmailLogs_id_persona")
  @@map("EmailLogs")
}
